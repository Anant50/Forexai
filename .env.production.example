# ==============================================================================
# ForexAI Pro - Production Environment Configuration Reference
# IMPORTANT: DO NOT commit the real `.env` file to version control.
# Copy this file to `.env` and replace the generic values with cryptographically
# secure passwords, legitimate API keys, and mapped domain names before deploying.
# ==============================================================================

# ------------------------------------------------------------------------------
# Framework Configuration
# ------------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false
APP_NAME="ForexAI Pro"

# [Critical Security] Generates a 256-bit secure key. 
# Execute this in bash to get a secure key: `openssl rand -hex 32`
SECRET_KEY=REPLACE_WITH_SECURE_GENERATED_KEY_HERE
ALGORITHM=HS256

# Explicitly isolate origins in production mitigating CORS leaks
ALLOWED_ORIGINS=["https://yourdomain.com", "https://api.yourdomain.com"]

# ------------------------------------------------------------------------------
# PostgreSQL Database Constraints
# ------------------------------------------------------------------------------
POSTGRES_USER=forexai_root
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_STRONG_DB_PASSWORD
POSTGRES_DB=forexai_prod
# Docker bridges network explicitly mapping 'db' gracefully
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Redis Cache Constraints
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_SECURE_STRONG_REDIS_PASSWORD

# ------------------------------------------------------------------------------
# Generative AI & Knowledge Engine (ChromaDB)
# ------------------------------------------------------------------------------
# Volume bounds mapped securely natively in docker-compose
CHROMA_DIR=/app/data/chroma
KNOWLEDGE_UPLOAD_DIR=/app/data/uploads

# ------------------------------------------------------------------------------
# External API Providers
# ------------------------------------------------------------------------------
# Optional Premium Market Data (Leave null to default to yFinance fallback)
ALPHA_VANTAGE_API_KEY=
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice

# ------------------------------------------------------------------------------
# Offsite Backup Automation (cron / backup_s3.sh)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BACKUP_BUCKET=s3://your-secure-aws-bucket-name

# ------------------------------------------------------------------------------
# SMTP Configuration (For Account/Alert notifications)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
FROM_EMAIL=noreply@yourdomain.com
